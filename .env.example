# Copy to .env and adjust as needed.

# Geolocation provider: "fake" (no external calls, deterministic data) or "ipstack".
GEOLOCATION_PROVIDER=fake

# Required when GEOLOCATION_PROVIDER=ipstack. Get a free key at https://ipstack.com/
# IPSTACK_API_KEY=your_ipstack_access_key

# Bearer token clients must send as "Authorization: Bearer <token>".
# If unset, authentication is disabled (handy for local poking).
API_TOKEN=secret-demo-token
